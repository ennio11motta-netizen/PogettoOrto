orto:LowRisk  a  <http://www.w3.org/2000/01/rdf-schema#Class> , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                orto:Risk , orto:LowRisk , <http://www.w3.org/2000/01/rdf-schema#Resource> .

<http://orto.example/plant/2>
        a                  orto:Plant , orto:AdvancedGrowthStage , orto:PlantInstance , orto:GrowthStage , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        orto:growthStage   "FRUTTIFICAZIONE";
        orto:hasForecast   <http://orto.example/forecast/4> , <http://orto.example/forecast/6> , <http://orto.example/forecast/5>;
        orto:hasRisk       <http://orto.example/risk/6> , <http://orto.example/risk/5> , <http://orto.example/risk/4> , <http://orto.example/risk/7>;
        orto:influencedBy  <http://orto.example/weather/4> , <http://orto.example/weather/5> , <http://orto.example/weather/6> , <http://orto.example/weather/7>;
        orto:storeGDD      "667.85"^^<http://www.w3.org/2001/XMLSchema#double> , "658.2"^^<http://www.w3.org/2001/XMLSchema#double> , "678.6"^^<http://www.w3.org/2001/XMLSchema#double> .

orto:hasForecast  a  <http://www.w3.org/1999/02/22-rdf-syntax-ns#Property> , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        <http://www.w3.org/2000/01/rdf-schema#domain>
                orto:Plant;
        <http://www.w3.org/2000/01/rdf-schema#range>
                orto:GrowthForecast .

<http://orto.example/weather/6>
        a                    orto:WeatherDay;
        orto:generatesRisk   <http://orto.example/risk/6>;
        orto:precipitazione  "0.0"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:tempMax         "28.8"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:tempMin         "12.7"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:umidita         "47.958333333333336"^^<http://www.w3.org/2001/XMLSchema#double> .

orto:hasRisk  a  <http://www.w3.org/1999/02/22-rdf-syntax-ns#Property> , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        <http://www.w3.org/2000/01/rdf-schema#domain>
                orto:Plant;
        <http://www.w3.org/2000/01/rdf-schema#range>
                orto:Risk .

