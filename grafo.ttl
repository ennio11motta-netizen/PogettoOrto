        a                    orto:WeatherDay;
        orto:generatesRisk   <http://orto.example/risk/1>;
        orto:precipitazione  "0.0"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:tempMax         "28.6"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:tempMin         "12.4"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:umidita         "48.0"^^<http://www.w3.org/2001/XMLSchema#double> .

<http://orto.example/risk/1>
        a                  orto:LowRisk , orto:Risk , orto:RiskAssessment , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        orto:consigli      "Nessun rischio rilevante.";
        orto:riskCaldo     "LOW";
        orto:riskFreddo    "LOW";
        orto:riskMalattia  "LOW";
        orto:riskVento     "LOW" .

orto:ModerateRisk  a  <http://www.w3.org/2000/01/rdf-schema#Class> , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                orto:Risk , orto:ModerateRisk , <http://www.w3.org/2000/01/rdf-schema#Resource> .

orto:CriticalRisk  a  <http://www.w3.org/2000/01/rdf-schema#Class> , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
