<http://orto.example/risk/5>
        a                  orto:LowRisk , orto:Risk , orto:RiskAssessment , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        orto:consigli      "Nessun rischio rilevante.";
        orto:riskCaldo     "LOW";
        orto:riskFreddo    "LOW";
        orto:riskMalattia  "LOW";
        orto:riskVento     "LOW" .

orto:generatesRisk  a  <http://www.w3.org/1999/02/22-rdf-syntax-ns#Property> , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        <http://www.w3.org/2000/01/rdf-schema#range>
                orto:Risk .

<http://orto.example/forecast/5>
        a                  orto:GrowthForecast , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        orto:percentCiclo  "83.48125"^^<http://www.w3.org/2001/XMLSchema#double> .

orto:EarlyGrowthStage
        a       <http://www.w3.org/2000/01/rdf-schema#Class> , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
