orto:AdvancedGrowthStage
        a       <http://www.w3.org/2000/01/rdf-schema#Class> , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                orto:GrowthStage , orto:AdvancedGrowthStage .

<http://orto.example/forecast/1>
        a                  orto:GrowthForecast , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        orto:percentCiclo  "82.5625"^^<http://www.w3.org/2001/XMLSchema#double> .

<http://orto.example/weather/4>
        a                    orto:WeatherDay;
        orto:generatesRisk   <http://orto.example/risk/4>;
        orto:precipitazione  "7.0"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:tempMax         "38.0"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:tempMin         "24.0"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:umidita         "85.0"^^<http://www.w3.org/2001/XMLSchema#double> .

<http://orto.example/risk/4>
        a                  orto:ModerateRisk , orto:Risk , orto:RiskAssessment , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        orto:consigli      "Rischio caldo medio: monitorare idratazione e temperatura.";
        orto:riskCaldo     "MEDIUM";
        orto:riskFreddo    "LOW";
        orto:riskMalattia  "LOW";
        orto:riskVento     "LOW" .

orto:influencedBy  a  <http://www.w3.org/1999/02/22-rdf-syntax-ns#Property> , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        <http://www.w3.org/2000/01/rdf-schema#domain>
                orto:Plant .

<http://orto.example/weather/2>
        a                    orto:WeatherDay;
        orto:generatesRisk   <http://orto.example/risk/2>;
        orto:precipitazione  "0.0"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:tempMax         "30.4"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:tempMin         "13.8"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:umidita         "47.916666666666664"^^<http://www.w3.org/2001/XMLSchema#double> .

<http://orto.example/risk/2>
        a                  orto:LowRisk , orto:Risk , orto:RiskAssessment , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        orto:consigli      "Nessun rischio rilevante.";
        orto:riskCaldo     "LOW";
        orto:riskFreddo    "LOW";
        orto:riskMalattia  "LOW";
        orto:riskVento     "LOW" .

<http://orto.example/plant/1>
        a                  orto:Plant , orto:AdvancedGrowthStage , orto:PlantInstance , orto:GrowthStage , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        orto:growthStage   "FRUTTIFICAZIONE";
        orto:hasForecast   <http://orto.example/forecast/2> , <http://orto.example/forecast/1> , <http://orto.example/forecast/3>;
        orto:hasRisk       <http://orto.example/risk/2> , <http://orto.example/risk/1> , <http://orto.example/risk/4> , <http://orto.example/risk/3>;
        orto:influencedBy  <http://orto.example/weather/4> , <http://orto.example/weather/1> , <http://orto.example/weather/2> , <http://orto.example/weather/3>;
        orto:storeGDD      "672.6"^^<http://www.w3.org/2001/XMLSchema#double> , "660.5"^^<http://www.w3.org/2001/XMLSchema#double> , "685.8000000000001"^^<http://www.w3.org/2001/XMLSchema#double> .

<http://orto.example/forecast/2>
        a                  orto:GrowthForecast , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        orto:percentCiclo  "84.075"^^<http://www.w3.org/2001/XMLSchema#double> .

