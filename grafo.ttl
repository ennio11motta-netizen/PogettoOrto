<http://orto.example/weather/3>
        a                    orto:WeatherDay;
        orto:generatesRisk   <http://orto.example/risk/3>;
        orto:precipitazione  "0.1"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:tempMax         "31.7"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:tempMin         "14.7"^^<http://www.w3.org/2001/XMLSchema#double>;
        orto:umidita         "56.333333333333336"^^<http://www.w3.org/2001/XMLSchema#double> .

orto:LowRisk  a  <http://www.w3.org/2000/01/rdf-schema#Class> , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        <http://www.w3.org/2000/01/rdf-schema#subClassOf>
                orto:Risk , orto:LowRisk , <http://www.w3.org/2000/01/rdf-schema#Resource> .

<http://orto.example/risk/3>
        a                  orto:LowRisk , orto:Risk , orto:RiskAssessment , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        orto:consigli      "Nessun rischio rilevante.";
        orto:riskCaldo     "LOW";
        orto:riskFreddo    "LOW";
        orto:riskMalattia  "LOW";
        orto:riskVento     "LOW" .

orto:hasForecast  a  <http://www.w3.org/1999/02/22-rdf-syntax-ns#Property> , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        <http://www.w3.org/2000/01/rdf-schema#domain>
                orto:Plant;
        <http://www.w3.org/2000/01/rdf-schema#range>
                orto:GrowthForecast .

<http://orto.example/forecast/3>
        a                  orto:GrowthForecast , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        orto:percentCiclo  "85.72500000000001"^^<http://www.w3.org/2001/XMLSchema#double> .

orto:hasRisk  a  <http://www.w3.org/1999/02/22-rdf-syntax-ns#Property> , <http://www.w3.org/2000/01/rdf-schema#Resource>;
        <http://www.w3.org/2000/01/rdf-schema#domain>
